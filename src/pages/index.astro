---
// ============================================================
// index.astro —— 首页（关于我，Tailwind 重构版）
// ============================================================
// 内容不变，全部样式改用 Tailwind class。
// 配色靠主题变量自动切换，本文件不写颜色硬编码。
// ============================================================

import BaseLayout from '../layouts/BaseLayout.astro';

const name = "LIYUAN";
const role = "计算机科学本科生";
const intro = "正在用 Astro + Tailwind CSS + Cloudflare 搭建本站点，从 Spring Boot/Vue3 转向现代 Serverless 栈。";
const links = [
  { label: "GitHub", url: "https://github.com/liyuan4LY" },
  { label: "Email", url: "mailto:562596639ly@gmail.com" },
];
---

<BaseLayout title="LIYUAN · 个人主页" description="LIYUAN 的个人主页，记录学习、项目与博客。">
  <h1 class="mb-2 text-3xl font-bold text-white md:text-4xl">{name}</h1>
  <p class="mb-6 text-base text-white/70">{role}</p>
  <p class="text-base leading-relaxed text-white/90 md:text-lg">{intro}</p>

  <h2 class="mt-10 mb-4 text-xl font-semibold text-white md:text-2xl">联系方式</h2>
  <ul class="flex flex-col gap-2">
    {links.map(link => (
      <li>
        <a
          href={link.url}
          class="text-white/90 underline-offset-4 hover:underline"
          style="color: var(--link-color);"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
