---
// ============================================================
// pages/blog/index.astro —— 博客列表页（Tailwind 重构版）
// ============================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(date: Date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
}
---

<BaseLayout
  title="博客 · LIYUAN"
  description="LIYUAN 的博客文章列表，记录学习与思考。"
>
  <h1 class="mb-2 text-3xl font-bold text-white md:text-4xl">博客</h1>
  <p class="mb-10 text-base text-white/70">学习笔记、项目记录、零散思考。</p>

  {posts.length === 0 ? (
    <p class="italic text-white/60">还没有文章。</p>
  ) : (
    <ul class="flex flex-col gap-6">
      {posts.map(post => (
        <li
          class="border-b pb-6 last:border-b-0"
          style="border-color: var(--card-border);"
        >
          <a href={`/blog/${post.id}`} class="group block">
            <h2
              class="mb-1 text-xl font-semibold text-white transition-colors group-hover:opacity-80 md:text-2xl"
            >
              {post.data.title}
            </h2>
            <time
              class="text-sm text-white/60"
              datetime={post.data.pubDate.toISOString()}
            >
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.description && (
              <p class="mt-2 text-white/80">{post.data.description}</p>
            )}
            {post.data.tags.length > 0 && (
              <ul class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <li
                    class="rounded px-2 py-1 text-xs"
                    style="background-color: rgba(255,255,255,0.12); color: var(--text-muted);"
                  >
                    {tag}
                  </li>
                ))}
              </ul>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
